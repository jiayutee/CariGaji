# Copy this file to .env and fill in your values. Never commit .env.

# Telegram bot credentials (from @BotFather and your chat ID)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Supabase (public anon key is safe to commit; service role key is NOT)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub PAT (fine-grained, read-only Actions/Contents) so the orchestrator
# can poll live deploy/run status via `gh`. Used as GH_TOKEN. Never commit.
GITHUB_TOKEN=github_pat_xxx
